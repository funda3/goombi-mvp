# Goombi environment variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Neon PostgreSQL
# Get this from: console.neon.tech -> your project -> Connection Details
# Format: postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/goombi?sslmode=require

# Google Places API (optional - for enrichment phase)
# Get this from: console.cloud.google.com -> APIs -> Places API
# Free tier: $200/month credit (~40,000 Place Details calls)
GOOGLE_PLACES_API_KEY=AIzaSy...
